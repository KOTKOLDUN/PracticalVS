#include <iostream>
#include <conio.h>
#include <windows.h>

using namespace std;

const int SIZE = 20;

// Функция для управления курсором (убирает мигание и лаги)
void setCursor(int x, int y) {
    COORD coord = { (SHORT)x, (SHORT)y };
    SetConsoleCursorPosition(GetStdHandle(STD_OUTPUT_HANDLE), coord);
}

// Функция скрытия текстового курсора
void hideCursor() {
    HANDLE consoleHandle = GetStdHandle(STD_OUTPUT_HANDLE);
    CONSOLE_CURSOR_INFO cursorInfo;
    GetConsoleCursorInfo(consoleHandle, &cursorInfo);
    cursorInfo.bVisible = false; 
    SetConsoleCursorInfo(consoleHandle, &cursorInfo);
}

// ФУНКЦИЯ ВЫВОДА КАРТЫ
void drawMap(int maze[SIZE][SIZE], int pX, int pY) {
    setCursor(0, 0); // Возвращаемся в начало вместо очистки экрана
    for (int i = 0; i < SIZE; i++) {
        for (int j = 0; j < SIZE; j++) {
            if (i == pY && j == pX) cout << "G";
            else if (maze[i][j] == 1) cout << "#";
            else if (maze[i][j] == 2) cout << "E";
            else if (maze[i][j] == 3) cout << "~";
            else cout << " ";
        }
        cout << "\n";
    }
}

int main() {
    hideCursor(); // Выключаем мигающий курсор

    int maze[SIZE][SIZE] = {
