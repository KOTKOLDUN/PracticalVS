#include <iostream>
#include <string>

using namespace std;

// Функция для вывода текста с выбором цвета
void ncout(string text, string color) {
    string code = "\033[0m"; // По умолчанию (белый/сброс)

    if (color == "1") code = "\033[31m";    // Красный
    else if (color == "2") code = "\033[32m"; // Зеленый
    else if (color == "3") code = "\033[33m"; // Желтый
    else if (color == "4") code = "\033[34m"; // Синий
    else if (color == "5") code = "\033[35m"; // Фиолетовый
    else if (color == "6") code = "\033[36m"; // Аква

    // Вывод: код цвета + текст + сброс цвета
    cout << code << text << "\033[0m" << endl;
}

int main() {
    // Пример использования по заданию
    ncout("Привет", "1");  // Красный
    
    // Цифры от 1 до 10 разными цветами
    ncout("1", "1");   // Красный
    ncout("2", "2");   // Зеленый
    ncout("3", "3");   // Желтый
    ncout("4", "4");   // Синий
    ncout("5", "5");   // Фиолетовый
    ncout("6", "6");   // Аква
    ncout("7", "1");   // Красный
    ncout("8", "2");   // Зеленый
    ncout("9", "3");   // Желтый
    ncout("10", "4");  // Синий

    return 0;
}
